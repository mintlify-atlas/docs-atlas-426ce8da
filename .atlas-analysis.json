  "keyFeatures": [
    "Colombian payroll compliance with legal concepts (EPS, AFP, transport subsidy)",
    "Flexible payment periods (biweekly/quincenal or monthly/mensual)",
    "Automated payroll calculation with earnings and deductions",
    "Employee management with comprehensive personal and work information",
    "Overtime and bonus tracking through novelties system",
    "Robust error handling with PostgreSQL SQLSTATE codes",
    "Transport subsidy calculation based on minimum wage multiples",
    "Configurable payroll concepts (mandatory and optional)"
  ],
